+
+#ifdef HAVE_USEC
+static int bool_commit_list(semanage_handle_t * handle,
+			    semanage_bool_t ** booleans, unsigned int count)
+{
+
+	void *target_blist = NULL;
+    const char *name;
+    unsigned int bcount = 0;
+    unsigned int i;
+    int curvalue, newvalue;
+    int use_USEC_backend = (semanage_compat_get_backend(handle) == SEMANAGE_SECURITY_BACKEND_USEC);
+
+    /* Allocate a sufficiently large array */
+    if (use_USEC_backend) {
+        target_blist = malloc(sizeof(usec_boolean_t) * count);
+    } else {
+        target_blist = malloc(sizeof(SELboolean) * count);
+    }
+    
+    if (target_blist == NULL)
+        goto omem;
+
+    /* Populate array */
+    for (i = 0; i < count; i++) {
+        name = semanage_bool_get_name(booleans[i]);
+        if (!name)
+            goto omem;   
+        newvalue = semanage_bool_get_value(booleans[i]);
+        curvalue = semanage_compat_security_get_boolean_active(handle, name);
+        if (newvalue == curvalue)
+            continue;
+        
+        if (use_USEC_backend) {
+            usec_boolean_t *usecblist = (usec_boolean_t *)target_blist;
+            usecblist[bcount].name = strdup(name);
+            if (usecblist[bcount].name == NULL)
+                goto omem;
+            usecblist[bcount].value = newvalue;
+        } else {
+            SELboolean *seblist = (SELboolean *)target_blist;
+            seblist[bcount].name = strdup(name);
+            if (seblist[bcount].name == NULL)
+                goto omem;
+            seblist[bcount].value = newvalue;
+        }
+        bcount++;
+    }
+    
+    /* Commit */
+    if (semanage_compat_security_set_boolean_list(handle, bcount, target_blist, 0) < 0) {
+        ERR(handle, "security backend commit failed");
+        goto err;
+    }
+
+    for (i = 0; i < bcount; i++) {
+        // 根据 backend 类型选择正确的结构体访问方式
+        if (use_USEC_backend) {
+            usec_boolean_t *usecblist = (usec_boolean_t *)target_blist;
+            free(usecblist[i].name);
+        } else {
+            SELboolean *seblist = (SELboolean *)target_blist;
+            free(seblist[i].name);
+        }
+    }
+    free(target_blist);
+    target_blist = NULL;
+    return STATUS_SUCCESS;
+
+  omem:
+    ERR(handle, "out of memory");
+
+  err:
+    ERR(handle, "could not commit boolean list");
+    if (target_blist) {
+        for (i = 0; i < bcount; i++) {
+            if (use_USEC_backend) {
+                usec_boolean_t *usecblist = (usec_boolean_t *)target_blist;
+                free(usecblist[i].name);
+            } else {
+                SELboolean *seblist = (SELboolean *)target_blist;
+                free(seblist[i].name);
+            }
+        }
+        free(target_blist);
+    }
+    return STATUS_ERR;
+}
+
+#else
 static int bool_commit_list(semanage_handle_t * handle,
 			    semanage_bool_t ** booleans, unsigned int count)
 {
@@ -108,7 +198,7 @@ static int bool_commit_list(semanage_handle_t * handle,
 		if (!name)
 			goto omem;	
 		newvalue = semanage_bool_get_value(booleans[i]);
-		curvalue = security_get_boolean_active(name);
+		curvalue = semanage_compat_security_get_boolean_active(handle, name);
 		if (newvalue == curvalue)
 			continue;
 		blist[bcount].name = strdup(name);
